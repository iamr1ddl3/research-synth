# research-synth — example env file (safe to commit)
# Copy to .env and fill in your own keys before running.

# === LLM PROVIDERS ===
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-v1-...
# OPENAI_API_KEY=sk-...   # Optional: only if using OpenAI direct instead of OpenRouter for GPT-4.1

# === BROWSER AUTOMATION ===
BROWSERBASE_API_KEY=bb_live_...
BROWSERBASE_PROJECT_ID=...

# === OBSERVABILITY ===
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://us.cloud.langfuse.com

# === SHARED INFRA ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/codeorch
